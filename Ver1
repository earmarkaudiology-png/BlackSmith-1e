    function removeCraftsman(employerState, craftsmanId) {
        employerState.craftsmen = _.filter(employerState.craftsmen, function (c) { return c.id !== craftsmanId; });
        employerState.quotes = _.filter(employerState.quotes, function (q) { return q.craftsmanId !== craftsmanId; });
    }

    function townLabel(town) {
        return String(town || 'Unspecified').replace(/,/g, ';').replace(/\|/g, '/').replace(/\}/g, ')');

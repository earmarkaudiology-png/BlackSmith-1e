    function getBlacksmithsForEmployer(employer) {
        if (!employer) return [];
        return _.filter(getEmployerState(employer.id).craftsmen, function (c) {
            return c && c.type === 'blacksmith';
        });
    }


    function getAllBlacksmiths() {
        return _.chain(state[STATE].employers || {})
            .keys()
            .map(function (employerId) {
                var employerState = getEmployerState(employerId);
                var owner = getObjById('character', employerId);
                return _.map(_.filter(employerState.craftsmen, function (c) {
                    return c && c.type === 'blacksmith';
                }), function (c) {
                    var copy = _.clone(c);
                    copy.ownerId = employerId;
                    copy.ownerName = owner ? (owner.get('name') || 'Employer') : 'Employer';
                    return copy;
                });
            })
            .flatten()
            .sortBy(function (c) {
                return ((c.name || '') + ' ' + (c.ownerName || '')).toLowerCase();
            })
            .value();
    }

    function getCraftsmanGlobal(craftsmanId) {
        return _.find(getAllBlacksmiths(), function (c) {
            return c && c.id === craftsmanId;
        }) || null;
    }

    function getBlacksmithsByTown(employer, town) {
        var normalizedTown = String(town || '').toLowerCase();
        return _.filter(getBlacksmithsForEmployer(employer), function (c) {
            return String(c.town || 'Unspecified').toLowerCase() === normalizedTown;
        });
    }

    function buildTownQuery(employer, label) {
        var towns;
        if (!employer) return '?{' + label + '|None,none}';
        towns = _.chain(getBlacksmithsForEmployer(employer))
            .map(function (c) { return c.town || 'Unspecified'; })
            .uniq(false, function (t) { return String(t).toLowerCase(); })
            .sortBy(function (t) { return String(t).toLowerCase(); })
            .value();
        if (!towns.length) return '?{' + label + '|None,none}';
        return '?{' + label + '|None,none|' + _.map(towns, function (t) {
            var safeTown = townLabel(t);
            return safeTown + ',' + safeTown;
        }).join('|') + '}';
    }

